# ============================================================
# AI Travel Planner — Environment Variables
# ============================================================

# ── Groq — THE ONLY KEY YOU NEED ────────────────────────────
# Free, fast, generous limits (30 req/min, 14,400 req/day)
# Get it free at: https://console.groq.com
# No credit card required.
GROQ_API_KEY=your_groq_api_key_here

# ── Everything else is free with no key required ────────────
# Driving routes  → OSRM          (openstreetmap.org)
# Rail estimates  → OSRM + Nominatim
# Geocoding       → Nominatim      (openstreetmap.org)
# Attractions     → Overpass API   (openstreetmap.org)
# Flights         → DuckDuckGo search + Groq analysis
# Hotels          → DuckDuckGo search + Groq analysis
